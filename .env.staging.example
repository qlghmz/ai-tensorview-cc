# Copy to .env.staging.local and fill in values (never commit)
# Staging: separate Supabase project OR local `supabase start` (recommended for testing)

# --- Supabase (staging project or local: http://127.0.0.1:54321) ---
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- AI (DashScope / 通义千问) ---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# --- Cloudflare deploy ---
WORKER_NAME=ai-tensorview-staging
# Leave empty to deploy to *.workers.dev only:
# CUSTOM_DOMAIN=staging.your-domain.com

# Optional: exact URL for npm run smoke:staging
# SMOKE_TEST_URL=https://ai-tensorview-staging.account.workers.dev

# Optional: bind custom domain (see scripts/bind-domain.mjs)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
