# Copy to .env.production.local and fill in values (never commit)
# Production: dedicated Supabase project + custom domain

# --- Supabase ---
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_PROD_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://YOUR_PROD_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- AI (DashScope / 通义千问) ---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# --- Cloudflare deploy ---
WORKER_NAME=ai-tensorview-cc
CUSTOM_DOMAIN=your-domain.com

# Optional: bind custom domain via DNS API token file `.cloudflare-dns-token`
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
