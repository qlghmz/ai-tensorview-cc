# Copy to .env.local for local development (never commit)
# For staging/production deploys use .env.staging.local / .env.production.local instead.

# --- Supabase ---
SUPABASE_PROJECT_ID=
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- AI (DashScope / 通义千问) ---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# --- Optional: Cloudflare DNS bind (scripts/bind-domain.mjs) ---
# Save DNS Edit token to `.cloudflare-dns-token` (not in this file — Wrangler would pick it up)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
# CUSTOM_DOMAIN=
# WORKER_NAME=

# --- Optional: Ollama (local / docker compose) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- Optional: OpenAI-compatible gateway ---
# CUSTOM_AI_API_KEY=
# CUSTOM_AI_BASE_URL=https://api.openai.com/v1
# CUSTOM_AI_MODEL=gpt-4o-mini
