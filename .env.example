# 复制为 .env.local 并填入真实值（勿提交 .env.local）
# 阿里云百炼 / DashScope OpenAI 兼容接口
DASHSCOPE_API_KEY=
# 可选：qwen-turbo | qwen-plus | qwen-max 等
DASHSCOPE_MODEL=qwen-plus

# 可选：自定义 OpenAI 兼容网关（优先级低于 DashScope 环境变量名时请清空 DASHSCOPE_API_KEY）
# CUSTOM_AI_API_KEY=
# CUSTOM_AI_BASE_URL=https://api.openai.com/v1
# CUSTOM_AI_MODEL=gpt-4o-mini
